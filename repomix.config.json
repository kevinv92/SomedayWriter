{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "compress": false,
    "showLineNumbers": true,
    "removeEmptyLines": false,
    "headerText": "writer-gui — Electron Markdown writer. See SPEC.md (design + decision history) and AGENTS.md (standards) first."
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": ["out", "dist", "repomix-output.*", "package-lock.json"]
  }
}
